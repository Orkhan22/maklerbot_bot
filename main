import requests
from bs4 import BeautifulSoup

TOKEN = "8666608099:AAFhdnrexdxUkfIeCpK_6zq1NdTEdQAVFKQ"
CHAT_ID = "644928091"

def start_bot():
    # Nərimanov, yeni tikili, 3 otaqlı linki
    URL = "https://bina.az/baki/neriman-nerimanov/alqi-satqi/menziller/yeni-tikili/3-otaqli"
    
    headers = {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
    }

    try:
        response = requests.get(URL, headers=headers, timeout=20)
        soup = BeautifulSoup(response.text, 'html.parser')
        
        # Saytdakı bütün elan linklərini tapırıq
        links = soup.find_all('a', href=True)
        
        found_link = None
        for a in links:
            href = a['href']
            # Şərt: Link '/items/' ilə başlamalıdır və uzunluğu 14-dən çox olmalıdır 
            # (Bu, /items/new kimi qısa linkləri avtomatik kənarlaşdırır)
            if href.startswith('/items/') and len(href) > 10:
                found_link = "https://bina.az" + href
                break 

        if found_link:
            msg = f"Nərimanovda yeni elan! 🏠\nLink: {found_link}"
            requests.post(f"https://api.telegram.org/bot{TOKEN}/sendMessage", json={"chat_id": CHAT_ID, "text": msg})
            print(f"Uğurla göndərildi: {found_link}")
        else:
            print("Elan tapılmadı.")

    except Exception as e:
        print(f"Xəta: {e}")

if __name__ == "__main__":
    start_bot()
