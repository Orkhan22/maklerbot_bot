import requests
from bs4 import BeautifulSoup

TOKEN = "8666608099:AAFhdnrexdxUkfIeCpK_6zq1NdTEdQAVFKQ"
CHAT_ID = "644928091"
URL = "https://bina.az/baki/neriman-nerimanov/alqi-satqi/menziller/yeni-tikili/3-otaqli"

def start_bot():
    print("--- Bot real elan axtarışına başladı ---")
    headers = {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
    }
    
    try:
        response = requests.get(URL, headers=headers, timeout=20)
        soup = BeautifulSoup(response.text, 'html.parser')
        
        # Bütün elan linklərini tapırıq
        all_links = soup.find_all('a', href=True)
        
        real_link = None
        for a in all_links:
            href = a['href']
            # ŞƏRT: Linkin içində '/items/' olmalıdır VƏ sonu rəqəmlə bitməlidir (məs: /items/423456)
            # Bu, '/items/new' kimi səhv linkləri avtomatik silir
            if href.startswith('/items/') and href.split('/')[-1].isdigit():
                real_link = "https://bina.az" + href
                break # İlk tapılan real elanı götür və dayan
        
        if real_link:
            msg = f"Nərimanovda yeni elan tapıldı! ✅\nLink: {real_link}"
            requests.post(f"https://api.telegram.org/bot{TOKEN}/sendMessage", json={"chat_id": CHAT_ID, "text": msg})
            print(f"Uğurla göndərildi: {real_link}")
        else:
            print("Uyğun mənzil linki tapılmadı.")
            
    except Exception as e:
        print(f"Xəta baş verdi: {e}")

if __name__ == "__main__":
    start_bot()
