import requests
from bs4 import BeautifulSoup

# Məlumatlarını bura yaz
TOKEN = "8666608099:AAFhdnrexdxUkfIeCpK_6zq1NdTEdQAVFKQ"
CHAT_ID = "644928091"
URL = "https://bina.az/baki/alqi-satqi/menziller/kohne-tikili?rooms[]=3&repair[]=1"

def check_bina():
    headers = {"User-Agent": "Mozilla/5.0"}
    try:
        response = requests.get(URL, headers=headers, timeout=20)
        soup = BeautifulSoup(response.text, 'html.parser')
        
        # Elanları tapırıq
        items = soup.select('.items-list-item')
        
        for item in items[:5]: # Hələlik yoxlamaq üçün ən son 5 elana baxsın
            link_tag = item.find('a', href=True)
            if link_tag:
                full_link = "https://bina.az" + link_tag['href']
                price_tag = item.find('span', class_='price-val')
                price = price_tag.text if price_tag else "Qiymət yoxdur"
                
                msg = f"Mənzil tapıldı! 🏠\nQiymət: {price}\nLink: {full_link}"
                requests.post(f"https://api.telegram.org/bot{TOKEN}/sendMessage", 
                             json={"chat_id": CHAT_ID, "text": msg})
                print("Mesaj göndərildi!")
                
    except Exception as e:
        print(f"Xəta: {e}")

if __name__ == "__main__":
    check_bina()
