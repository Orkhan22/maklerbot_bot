import requests
from bs4 import BeautifulSoup

TOKEN = "8666608099:AAFhdnrexdxUkfIeCpK_6zq1NdTEdQAVFKQ"
CHAT_ID = "644928091"
# Axtarış linkin (Nərimanov, 3 otaq, Yeni tikili)
URL = "https://bina.az/baki/neriman-nerimanov/alqi-satqi/menziller/yeni-tikili/3-otaqli"

def start_bot():
    headers = {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
    }

    try:
        response = requests.get(URL, headers=headers, timeout=20)
        soup = BeautifulSoup(response.text, 'html.parser')
        
        # Bütün elan bloklarını tapırıq
        items = soup.find_all('div', class_='items-list-item')

        if items:
            first_item = items[0]
            
            # 1. Linki tapırıq
            link_tag = first_item.find('a', href=True)
            link = "https://bina.az" + link_tag['href'] if link_tag else "Link tapılmadı"
            
            # 2. Qiyməti tapırıq
            price_val = first_item.find('span', class_='price-val')
            price_cur = first_item.find('span', class_='price-cur')
            
            full_price = "Məlum deyil"
            if price_val and price_cur:
                full_price = f"{price_val.text.strip()} {price_cur.text.strip()}"
            
            # 3. Kiçik detalları tapırıq (məsələn: sahə, mərtəbə - adətən 'location' daxilində olur)
            details = first_item.find('div', class_='location')
            location_text = details.text.strip() if details else "Nərimanov"

            # Telegram Mesajı Formatı
            msg_text = (
                f"🏠 *Nərimanovda yeni elan!*\n\n"
                f"💰 *Qiymət:* {full_price}\n"
                f"📍 *Yer:* {location_text}\n"
                f"🛏 *Otaq:* 3 otaqlı\n\n"
                f"🔗 [Elana keçid et]({link})"
            )

            # Mesajı göndəririk (Markdown istifadə edirik ki, qalın görünsün)
            requests.post(
                f"https://api.telegram.org/bot{TOKEN}/sendMessage", 
                json={
                    "chat_id": CHAT_ID, 
                    "text": msg_text, 
                    "parse_mode": "Markdown"
                }
            )
            print(f"Uğurla göndərildi: {full_price} - {link}")
        else:
            print("Səhifədə elan bloku tapılmadı.")

    except Exception as e:
        print(f"Xəta: {e}")

if __name__ == "__main__":
    start_bot()    # Bu Bina.az-ı yoxlayır
    check_turbo()  # Bu Turbo.az-ı yoxlayır
